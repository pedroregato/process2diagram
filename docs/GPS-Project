3. Alertas Inteligentes (não alarmistas):
class TimelineAlerts:
    def generate_alerts(self, project_state):
        """Gera alertas contextuais e úteis"""

        alerts = []

        # 1. Atrasos sutis
        if self._is_phase_taking_longer_than_usual(project_state):
            alerts.append({
                "type": "info",
                "title": "Fase está durando mais que o habitual",
                "message": f"A Fase {current_phase} está em {duration} vs. {avg_duration} normalmente",
                "suggestion": "Verificar se há bloqueadores não discutidos",
                "severity": "low"
            })

        # 2. Mudança de padrão
        if self._detect_pattern_change(project_state):
            alerts.append({
                "type": "insight",
                "title": "Padrão de discussão mudou",
                "message": "Últimas reuniões têm foco diferente das anteriores",
                "suggestion": "Pode indicar mudança de prioridades ou novo desafio",
                "severity": "medium"
            })

        # 3. Oportunidades
        if self._detect_acceleration_opportunity(project_state):
            alerts.append({
                "type": "opportunity",
                "title": "Oportunidade de avançar fase",
                "message": "Critérios da fase atual estão 85% atendidos",
                "suggestion": "Considerar revisão antecipada para liberar recursos",
                "severity": "low"
            })

        return alerts

