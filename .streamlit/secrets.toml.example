# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Template for production credentials.
#
# 1. Copy this file to .streamlit/secrets.toml  (never commit secrets.toml)
# 2. Generate password hashes:
#       python setup/generate_password_hash.py
# 3. Replace the placeholder hashes below with real ones.
#
# On Streamlit Cloud:
#   App → Settings → Secrets → paste the contents of your secrets.toml
# ─────────────────────────────────────────────────────────────────────────────

[auth.users.admin]
name          = "Administrador"
password_hash = "sha256$<paste-salt>$<paste-hash>"

# Add more users as needed:
# [auth.users.joao]
# name          = "João Silva"
# password_hash = "sha256$<paste-salt>$<paste-hash>"
