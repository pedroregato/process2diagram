<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://process2diagram.io/bpmn" id="definitions_1" exporter="Process2Diagram" exporterVersion="3.0"><bpmn:process id="process_1" name="Cadastro de Estrutura e Organograma de Escola" isExecutable="false" processType="None"><bpmn:laneSet id="pool_1_lset"><bpmn:lane id="lane_auditoria" name="Auditoria"><bpmn:flowNodeRef>S01</bpmn:flowNodeRef><bpmn:flowNodeRef>S02</bpmn:flowNodeRef><bpmn:flowNodeRef>S03</bpmn:flowNodeRef><bpmn:flowNodeRef>S04</bpmn:flowNodeRef><bpmn:flowNodeRef>S06</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_start</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="lane_gestores_validadores" name="Gestores Validadores"><bpmn:flowNodeRef>S05</bpmn:flowNodeRef><bpmn:flowNodeRef>S07</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_end</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="ev_start" name="Início" /><bpmn:userTask id="S01" name="Iniciar cadastro de organograma"><bpmn:documentation>Usuário clica no botão 'Cadastro de estrutura e organograma de escola' para iniciar o fluxo. O sistema exibe uma tela para preenchimento de título (opcional) e confirmação.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S02" name="Preencher dados da escola"><bpmn:documentation>Usuário preenche o formulário com código da escola, nome da escola, diretor responsável, e anexa arquivos obrigatórios (organograma em PDF e e-mail de aprovação). O sistema valida campos obrigatórios.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S03" name="Cadastrar unidades do organograma"><bpmn:documentation>Usuário cadastra cada unidade (caixinha) do organograma, preenchendo tipo, código, nome, responsável, hierarquia (vinculação à unidade superior) e indica se possui catálogo técnico (sim/não). O sistema soma automaticamente o total de unidades e catálogos previstos.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S04" name="Enviar para validação"><bpmn:documentation>Usuário conclui o cadastro das unidades e clica em 'Enviar para validação'. O fluxo é direcionado para a equipe de gestores validadores.</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S05" name="Validar cadastro do organograma"><bpmn:documentation>Validador acessa a tarefa, visualiza o organograma anexado e os dados cadastrados, conferindo a consistência. Pode aceitar ou devolver para ajustes.</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S06" name="Ajustar cadastro (se necessário)"><bpmn:documentation>Se devolvido, o usuário da auditoria corrige os pontos indicados nas observações do validador e reenvia para validação.</bpmn:documentation></bpmn:userTask><bpmn:serviceTask id="S07" name="Finalizar processo"><bpmn:documentation>Validador aceita o cadastro. O sistema executa atividades automáticas de finalização (geração de documento, atualização de status) e encerra o fluxo.</bpmn:documentation></bpmn:serviceTask><bpmn:endEvent id="ev_end" name="Fim" /><bpmn:sequenceFlow id="sf_start" name="" sourceRef="ev_start" targetRef="S01" /><bpmn:sequenceFlow id="sf_001" name="" sourceRef="S01" targetRef="S02" /><bpmn:sequenceFlow id="sf_002" name="" sourceRef="S02" targetRef="S03" /><bpmn:sequenceFlow id="sf_003" name="" sourceRef="S03" targetRef="S04" /><bpmn:sequenceFlow id="sf_004" name="" sourceRef="S04" targetRef="S05" /><bpmn:sequenceFlow id="sf_005" name="sim" sourceRef="S05" targetRef="S07"><bpmn:conditionExpression xsi:type="tFormalExpression">Cadastro aprovado</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_006" name="não" sourceRef="S05" targetRef="S06"><bpmn:conditionExpression xsi:type="tFormalExpression">Cadastro devolvido para ajustes</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_007" name="" sourceRef="S06" targetRef="S04" /><bpmn:sequenceFlow id="sf_end" name="" sourceRef="S07" targetRef="ev_end" /></bpmn:process><bpmn:collaboration id="collab_1"><bpmn:participant id="pool_1" name="Cadastro de Estrutura e Organograma de Escola" processRef="process_1" /></bpmn:collaboration><bpmndi:BPMNDiagram id="diagram_1"><bpmndi:BPMNPlane id="plane_1" bpmnElement="collab_1"><bpmndi:BPMNShape id="pool_1_di" bpmnElement="pool_1" isHorizontal="true"><dc:Bounds x="0" y="0" width="1642" height="360" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_auditoria_di" bpmnElement="lane_auditoria" isHorizontal="true"><dc:Bounds x="100" y="0" width="1542" height="180" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="10" width="80" height="160" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_gestores_validadores_di" bpmnElement="lane_gestores_validadores" isHorizontal="true"><dc:Bounds x="100" y="180" width="1542" height="180" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="190" width="80" height="160" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start"><dc:Bounds x="280" y="72" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="280" y="50" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S01_di" bpmnElement="S01"><dc:Bounds x="386" y="60" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="386" y="122" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S02_di" bpmnElement="S02"><dc:Bounds x="576" y="60" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="576" y="122" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S03_di" bpmnElement="S03"><dc:Bounds x="766" y="60" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="766" y="122" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S04_di" bpmnElement="S04"><dc:Bounds x="956" y="60" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="956" y="122" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S05_di" bpmnElement="S05"><dc:Bounds x="1146" y="245" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1146" y="297" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S06_di" bpmnElement="S06"><dc:Bounds x="1266" y="60" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1266" y="122" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S07_di" bpmnElement="S07"><dc:Bounds x="1266" y="240" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1266" y="302" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end"><dc:Bounds x="1456" y="252" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1456" y="230" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNEdge id="sf_start_di" bpmnElement="sf_start"><di:waypoint x="316" y="90" /><di:waypoint x="386" y="90" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_001_di" bpmnElement="sf_001"><di:waypoint x="506" y="90" /><di:waypoint x="576" y="90" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_002_di" bpmnElement="sf_002"><di:waypoint x="696" y="90" /><di:waypoint x="766" y="90" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_003_di" bpmnElement="sf_003"><di:waypoint x="886" y="90" /><di:waypoint x="956" y="90" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_004_di" bpmnElement="sf_004"><di:waypoint x="1076" y="90" /><di:waypoint x="1146" y="270" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_005_di" bpmnElement="sf_005"><di:waypoint x="1196" y="270" /><di:waypoint x="1266" y="270" /><bpmndi:BPMNLabel><dc:Bounds x="1201" y="254" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_006_di" bpmnElement="sf_006"><di:waypoint x="1196" y="270" /><di:waypoint x="1266" y="90" /><bpmndi:BPMNLabel><dc:Bounds x="1201" y="164" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_007_di" bpmnElement="sf_007"><di:waypoint x="1386" y="90" /><di:waypoint x="956" y="90" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_end_di" bpmnElement="sf_end"><di:waypoint x="1386" y="270" /><di:waypoint x="1456" y="270" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>