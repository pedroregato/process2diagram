<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://process2diagram.io/bpmn" id="definitions_1" exporter="Process2Diagram" exporterVersion="3.0"><bpmn:process id="process_1" name="Processo de Cadastro e Validação de Unidade com Organograma" isExecutable="false" processType="None"><bpmn:laneSet id="pool_1_lset"><bpmn:lane id="lane_equipe" name="Equipe"><bpmn:flowNodeRef>S01</bpmn:flowNodeRef><bpmn:flowNodeRef>S02</bpmn:flowNodeRef><bpmn:flowNodeRef>S03</bpmn:flowNodeRef><bpmn:flowNodeRef>S04</bpmn:flowNodeRef><bpmn:flowNodeRef>S07</bpmn:flowNodeRef><bpmn:flowNodeRef>S08</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_start</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_end</bpmn:flowNodeRef><bpmn:flowNodeRef>lnk_catch_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="lane_equipe_gestora" name="Equipe Gestora"><bpmn:flowNodeRef>S05</bpmn:flowNodeRef><bpmn:flowNodeRef>S06</bpmn:flowNodeRef><bpmn:flowNodeRef>lnk_throw_1</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="ev_start" name="Início" /><bpmn:userTask id="S01" name="Cadastrar unidade no sistema"><bpmn:documentation>O usuário inicia o cadastro de uma nova unidade (ex: tesouraria, secretaria, compras) no sistema, inserindo código e nome da unidade.</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S02" name="Decidir sobre unidades filhas"><bpmn:documentation>Após cadastrar a unidade principal, o usuário decide se deseja cadastrar unidades filhas (subordinadas) ou enviar direto para validação.</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S03" name="Cadastrar unidades filhas"><bpmn:documentation>Se o usuário optar por cadastrar unidades filhas, ele insere as subunidades (ex: Secretaria de Registros Acadêmicos, Gerência de Compras) vinculadas à unidade principal.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S04" name="Enviar para validação"><bpmn:documentation>O cadastro da unidade (com ou sem unidades filhas) é enviado para a atividade de validação pela equipe gestora.</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S05" name="Validar cadastro da unidade"><bpmn:documentation>A equipe gestora valida o cadastro da unidade. Se houver erros, pode devolver para ajustes; se estiver correto, aprova e permite abertura de outras atividades.</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S06" name="Devolver para ajustes"><bpmn:documentation>Se a validação identificar erros no cadastro, a equipe gestora devolve para a equipe que cadastrou corrigir as informações.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S07" name="Abrir atividades relacionadas"><bpmn:documentation>Após validação aprovada, o sistema permite abrir atividades como catálogo técnico (CT), instrução de trabalho (ITE), fluxo, ou outras, conforme necessidade da unidade.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S08" name="Classificar nível de interesse BI"><bpmn:documentation>Para processos que serão incluídos no Business Intelligence (BI), o usuário classifica o nível de interesse como estratégico (presidência/diretoria), tático (gerencial) ou operacional (equipes de trabalho).</bpmn:documentation></bpmn:userTask><bpmn:endEvent id="ev_end" name="Fim" /><bpmn:intermediateThrowEvent id="lnk_throw_1" name="L1"><bpmn:linkEventDefinition id="lnk_throw_1_def" /></bpmn:intermediateThrowEvent><bpmn:intermediateCatchEvent id="lnk_catch_1" name="L1"><bpmn:linkEventDefinition id="lnk_catch_1_def" /></bpmn:intermediateCatchEvent><bpmn:sequenceFlow id="sf_start" name="" sourceRef="ev_start" targetRef="S01" /><bpmn:sequenceFlow id="sf_001" name="" sourceRef="S01" targetRef="S02" /><bpmn:sequenceFlow id="sf_002" name="sim" sourceRef="S02" targetRef="S03"><bpmn:conditionExpression xsi:type="tFormalExpression">cadastrar unidades filhas</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_003" name="não" sourceRef="S02" targetRef="S04"><bpmn:conditionExpression xsi:type="tFormalExpression">enviar direto para validação</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_004" name="" sourceRef="S03" targetRef="S04" /><bpmn:sequenceFlow id="sf_005" name="" sourceRef="S04" targetRef="S05" /><bpmn:sequenceFlow id="sf_006" name="não" sourceRef="S05" targetRef="S06"><bpmn:conditionExpression xsi:type="tFormalExpression">cadastro com erros</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_007" name="sim" sourceRef="S05" targetRef="S07"><bpmn:conditionExpression xsi:type="tFormalExpression">cadastro aprovado</bpmn:conditionExpression></bpmn:sequenceFlow><bpmn:sequenceFlow id="sf_008_a" name="" sourceRef="S06" targetRef="lnk_throw_1" /><bpmn:sequenceFlow id="sf_008_b" name="" sourceRef="lnk_catch_1" targetRef="S01" /><bpmn:sequenceFlow id="sf_009" name="" sourceRef="S07" targetRef="S08" /><bpmn:sequenceFlow id="sf_end" name="" sourceRef="S08" targetRef="ev_end" /></bpmn:process><bpmn:collaboration id="collab_1"><bpmn:participant id="pool_1" name="Processo de Cadastro e Validação de Unidade com Organograma" processRef="process_1" /></bpmn:collaboration><bpmndi:BPMNDiagram id="diagram_1"><bpmndi:BPMNPlane id="plane_1" bpmnElement="collab_1"><bpmndi:BPMNShape id="pool_1_di" bpmnElement="pool_1" isHorizontal="true"><dc:Bounds x="0" y="0" width="1762" height="406" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_equipe_di" bpmnElement="lane_equipe" isHorizontal="true"><dc:Bounds x="100" y="0" width="1662" height="226" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="10" width="80" height="206" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_equipe_gestora_di" bpmnElement="lane_equipe_gestora" isHorizontal="true"><dc:Bounds x="100" y="226" width="1662" height="180" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="236" width="80" height="160" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start"><dc:Bounds x="280" y="95" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="280" y="73" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S01_di" bpmnElement="S01"><dc:Bounds x="386" y="111" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="386" y="173" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S02_di" bpmnElement="S02"><dc:Bounds x="576" y="88" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="576" y="140" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S03_di" bpmnElement="S03"><dc:Bounds x="696" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="696" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S04_di" bpmnElement="S04"><dc:Bounds x="886" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="886" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S05_di" bpmnElement="S05"><dc:Bounds x="1076" y="291" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1076" y="343" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S06_di" bpmnElement="S06"><dc:Bounds x="1196" y="286" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1196" y="348" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S07_di" bpmnElement="S07"><dc:Bounds x="1196" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1196" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S08_di" bpmnElement="S08"><dc:Bounds x="1386" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1386" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end"><dc:Bounds x="1576" y="95" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1576" y="73" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lnk_throw_1_di" bpmnElement="lnk_throw_1"><dc:Bounds x="1428" y="298" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1428" y="276" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lnk_catch_1_di" bpmnElement="lnk_catch_1"><dc:Bounds x="428" y="55" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="428" y="33" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNEdge id="sf_start_di" bpmnElement="sf_start"><di:waypoint x="316" y="113" /><di:waypoint x="386" y="141" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_001_di" bpmnElement="sf_001"><di:waypoint x="506" y="141" /><di:waypoint x="576" y="113" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_002_di" bpmnElement="sf_002"><di:waypoint x="626" y="113" /><di:waypoint x="696" y="113" /><bpmndi:BPMNLabel><dc:Bounds x="631" y="97" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_003_di" bpmnElement="sf_003"><di:waypoint x="626" y="113" /><di:waypoint x="886" y="113" /><bpmndi:BPMNLabel><dc:Bounds x="726" y="97" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_004_di" bpmnElement="sf_004"><di:waypoint x="816" y="113" /><di:waypoint x="886" y="113" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_005_di" bpmnElement="sf_005"><di:waypoint x="1006" y="113" /><di:waypoint x="1076" y="316" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_006_di" bpmnElement="sf_006"><di:waypoint x="1126" y="316" /><di:waypoint x="1196" y="316" /><bpmndi:BPMNLabel><dc:Bounds x="1131" y="300" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_007_di" bpmnElement="sf_007"><di:waypoint x="1126" y="316" /><di:waypoint x="1196" y="113" /><bpmndi:BPMNLabel><dc:Bounds x="1131" y="198" width="60" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_008_a_di" bpmnElement="sf_008_a"><di:waypoint x="1316" y="316" /><di:waypoint x="1428" y="316" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_008_b_di" bpmnElement="sf_008_b"><di:waypoint x="446" y="91" /><di:waypoint x="446" y="111" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_009_di" bpmnElement="sf_009"><di:waypoint x="1316" y="113" /><di:waypoint x="1386" y="113" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="sf_end_di" bpmnElement="sf_end"><di:waypoint x="1506" y="113" /><di:waypoint x="1576" y="113" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>