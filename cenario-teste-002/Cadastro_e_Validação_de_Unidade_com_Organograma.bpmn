<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" targetNamespace="http://process2diagram.io/bpmn" id="definitions_1" exporter="Process2Diagram" exporterVersion="3.0"><bpmn:process id="process_1" name="Cadastro e Validação de Unidade com Organograma" isExecutable="false" processType="None"><bpmn:laneSet id="pool_1_lset"><bpmn:lane id="lane_equipe" name="Equipe"><bpmn:flowNodeRef>S01</bpmn:flowNodeRef><bpmn:flowNodeRef>S02</bpmn:flowNodeRef><bpmn:flowNodeRef>S03</bpmn:flowNodeRef><bpmn:flowNodeRef>S04</bpmn:flowNodeRef><bpmn:flowNodeRef>S08</bpmn:flowNodeRef><bpmn:flowNodeRef>S09</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_start</bpmn:flowNodeRef><bpmn:flowNodeRef>lnk_catch_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="lane_equipe_gestora" name="Equipe Gestora"><bpmn:flowNodeRef>S05</bpmn:flowNodeRef><bpmn:flowNodeRef>S06</bpmn:flowNodeRef><bpmn:flowNodeRef>S07</bpmn:flowNodeRef><bpmn:flowNodeRef>lnk_throw_1</bpmn:flowNodeRef></bpmn:lane><bpmn:lane id="lane_equipe_com_deise" name="Equipe com Deise"><bpmn:flowNodeRef>S10</bpmn:flowNodeRef><bpmn:flowNodeRef>S11</bpmn:flowNodeRef><bpmn:flowNodeRef>ev_end</bpmn:flowNodeRef></bpmn:lane></bpmn:laneSet><bpmn:startEvent id="ev_start" name="Início" /><bpmn:userTask id="S01" name="Cadastrar unidade no sistema"><bpmn:documentation>Equipe cadastra nova unidade (ex: tesouraria, secretaria) com código e nome. [AMBIGUIDADE: não ficou claro quem executa — assumido como 'Equipe']</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S02" name="Decidir se cadastra unidades filhas"><bpmn:documentation>Após cadastrar a unidade principal, decide-se se serão cadastradas unidades subordinadas (ex: 9.3 Secretaria, 9.5 Compras sob a unidade 9).</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S03" name="Cadastrar unidades filhas"><bpmn:documentation>Equipe cadastra unidades subordinadas, vinculando-as à unidade principal.</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S04" name="Enviar para validação"><bpmn:documentation>Equipe envia o cadastro da unidade (com ou sem filhas) para validação pela equipe gestora.</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S05" name="Validar cadastro da unidade"><bpmn:documentation>Equipe gestora valida o cadastro da unidade. Pode aprovar, solicitar ajustes ou devolver para correção.</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S06" name="Solicitar ajustes"><bpmn:documentation>Equipe gestora solicita ajustes no cadastro da unidade (ex: correção de código, nome, vínculos).</bpmn:documentation></bpmn:userTask><bpmn:exclusiveGateway id="S07" name="Decidir sobre organograma"><bpmn:documentation>Após validação, decide-se se a unidade terá organograma (obrigatório para escolas, opcional para outras unidades).</bpmn:documentation></bpmn:exclusiveGateway><bpmn:userTask id="S08" name="Cadastrar organograma"><bpmn:documentation>Equipe cadastra organograma para a unidade (ex: escola), incluindo data de referência e versões (atual/obsoletas).</bpmn:documentation></bpmn:userTask><bpmn:userTask id="S09" name="Preencher planilha de migração"><bpmn:documentation>Equipe preenche planilha Excel/TXT com informações da unidade: código, nome, se tem organograma, data de referência, quantidade de processos, etc., para corte de migração.</bpmn:documentation></bpmn:userTask><bpmn:businessRuleTask id="S10" name="Classificar nível de BI"><bpmn:documentation>Equipe (com Deise) classifica processos da unidade para BI: estratégico (presidente), tático (gerencial) ou operacional (equipes). [AMBIGUIDADE: não ficou claro quem executa — assumido como 'Equipe com Deise']</bpmn:documentation></bpmn:businessRuleTask><bpmn:userTask id="S11" name="Roteirizar próximas ações"><bpmn:documentation>Após cadastro e classificação, sistema permite escolher próximas ações: criar catálogo técnico, instrução de trabalho, fluxo BPMN, etc.</bpmn:documentation></bpmn:userTask><bpmn:endEvent id="ev_end" name="Fim" /><bpmn:intermediateThrowEvent id="lnk_throw_1" name="L1"><bpmn:linkEventDefinition id="lnk_throw_1_def" /></bpmn:intermediateThrowEvent><bpmn:intermediateCatchEvent id="lnk_catch_1" name="L1"><bpmn:linkEventDefinition id="lnk_catch_1_def" /></bpmn:intermediateCatchEvent><bpmn:sequenceFlow id="sf_start" name="" sourceRef="ev_start" targetRef="S01" /><bpmn:sequenceFlow id="sf_001" name="" sourceRef="S01" targetRef="S02" /><bpmn:sequenceFlow id="sf_002" name="sim" sourceRef="S02" targetRef="S03" /><bpmn:sequenceFlow id="sf_003" name="não" sourceRef="S02" targetRef="S04" /><bpmn:sequenceFlow id="sf_004" name="" sourceRef="S03" targetRef="S04" /><bpmn:sequenceFlow id="sf_005" name="" sourceRef="S04" targetRef="S05" /><bpmn:sequenceFlow id="sf_006" name="com ajustes" sourceRef="S05" targetRef="S06" /><bpmn:sequenceFlow id="sf_007" name="aprovado" sourceRef="S05" targetRef="S07" /><bpmn:sequenceFlow id="sf_008_a" name="" sourceRef="S06" targetRef="lnk_throw_1" /><bpmn:sequenceFlow id="sf_008_b" name="" sourceRef="lnk_catch_1" targetRef="S01" /><bpmn:sequenceFlow id="sf_009" name="sim" sourceRef="S07" targetRef="S08" /><bpmn:sequenceFlow id="sf_010" name="não" sourceRef="S07" targetRef="S09" /><bpmn:sequenceFlow id="sf_011" name="" sourceRef="S08" targetRef="S09" /><bpmn:sequenceFlow id="sf_012" name="" sourceRef="S09" targetRef="S10" /><bpmn:sequenceFlow id="sf_013" name="" sourceRef="S10" targetRef="S11" /><bpmn:sequenceFlow id="sf_end" name="" sourceRef="S11" targetRef="ev_end" /></bpmn:process><bpmn:collaboration id="collab_1"><bpmn:participant id="pool_1" name="Cadastro e Validação de Unidade com Organograma" processRef="process_1" /></bpmn:collaboration><bpmndi:BPMNDiagram id="diagram_1"><bpmndi:BPMNPlane id="plane_1" bpmnElement="collab_1"><bpmndi:BPMNShape id="pool_1_di" bpmnElement="pool_1" isHorizontal="true"><dc:Bounds x="0" y="0" width="2332" height="702" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_equipe_di" bpmnElement="lane_equipe" isHorizontal="true"><dc:Bounds x="100" y="0" width="2232" height="226" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="10" width="80" height="206" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_equipe_gestora_di" bpmnElement="lane_equipe_gestora" isHorizontal="true"><dc:Bounds x="100" y="226" width="2232" height="296" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="236" width="80" height="276" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lane_equipe_com_deise_di" bpmnElement="lane_equipe_com_deise" isHorizontal="true"><dc:Bounds x="100" y="522" width="2232" height="180" /><bpmndi:BPMNLabel><dc:Bounds x="110" y="532" width="80" height="160" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_start_di" bpmnElement="ev_start"><dc:Bounds x="280" y="95" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="280" y="73" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S01_di" bpmnElement="S01"><dc:Bounds x="386" y="111" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="386" y="173" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S02_di" bpmnElement="S02"><dc:Bounds x="576" y="88" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="576" y="140" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S03_di" bpmnElement="S03"><dc:Bounds x="696" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="696" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S04_di" bpmnElement="S04"><dc:Bounds x="886" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="886" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S05_di" bpmnElement="S05"><dc:Bounds x="1076" y="349" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1076" y="401" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S06_di" bpmnElement="S06"><dc:Bounds x="1196" y="281" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1196" y="343" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S07_di" bpmnElement="S07"><dc:Bounds x="1231" y="361" width="50" height="50" /><bpmndi:BPMNLabel><dc:Bounds x="1231" y="413" width="50" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S08_di" bpmnElement="S08"><dc:Bounds x="1386" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1386" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S09_di" bpmnElement="S09"><dc:Bounds x="1576" y="83" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1576" y="145" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S10_di" bpmnElement="S10"><dc:Bounds x="1766" y="582" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1766" y="644" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="S11_di" bpmnElement="S11"><dc:Bounds x="1956" y="582" width="120" height="60" /><bpmndi:BPMNLabel><dc:Bounds x="1956" y="644" width="120" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="ev_end_di" bpmnElement="ev_end"><dc:Bounds x="2146" y="594" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="2146" y="572" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lnk_throw_1_di" bpmnElement="lnk_throw_1"><dc:Bounds x="1333" y="293" width="36" height="36" /><bpmndi:BPMNLabel><dc:Bounds x="1333" y="271" width="36" height="20" /></bpmndi:BPMNLabel></bpmndi:BPMNShape><bpmndi:BPMNShape id="lnk_catch_1_di" bpmnElement="lnk_catch_1"><dc:Bounds x="428" y="55" width="3