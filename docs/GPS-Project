# meeting_timeline_mapping.py
class TimelineMapper:
    def map_meeting_to_timeline(self, meeting_data, timeline):
        """Mapeia uma reunião para o cronograma"""

        mapping = {
            "meeting_id": meeting_data["id"],
            "date": meeting_data["date"],

            # Onde estamos?
            "current_phase": self._get_phase_for_date(
                meeting_data["date"], 
                timeline
            ),

            # O que discutimos?
            "discussed_topics": self._extract_topics(
                meeting_data["transcript"]
            ),

            # Quanto tempo gastamos?
            "time_spent_by_topic": self._analyze_time_distribution(
                meeting_data["transcript"]
            ),

            # Alinhamento
            "alignment_score": self._calculate_alignment(
                discussed_topics, 
                current_phase
            ),

            # Insights
            "insights": self._generate_insights(
                meeting_data, 
                timeline
            )
        }

        return mapping

